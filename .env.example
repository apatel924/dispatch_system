# Firebase Client
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
# Bucket must exist in the same Firebase/GCP project (enable Storage in console; billing required).
# Use the bucket host name only (e.g. project-id.firebasestorage.app) — not a gs:// URL.
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID

# Firebase Admin
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_CLIENT_EMAIL=YOUR_FIREBASE_CLIENT_EMAIL
FIREBASE_PRIVATE_KEY="YOUR_FIREBASE_PRIVATE_KEY"

# App
NEXT_PUBLIC_APP_URL=YOUR_APP_URL
# Server-only canonical URL for SMS links (preferred over NEXT_PUBLIC_APP_URL in production)
# APP_URL=https://your-production-domain.com
NEXT_PUBLIC_USE_API=true
# Dev only: enable mock admin data when NEXT_PUBLIC_USE_API is not true.
# Never set in production.
# NEXT_PUBLIC_ENABLE_DEV_MOCK=true
# Business timezone for operational day boundaries (default: America/Edmonton).
# Server-only — do not use NEXT_PUBLIC_. Uses IANA zones (handles MST/MDT).
APP_TIMEZONE=America/Edmonton
# Admin and driver portals use separate Firebase Auth instances (named apps) so both
# can stay signed in in the same browser. No NEXT_PUBLIC_TAB_SCOPED_AUTH needed.

# Seed users
SEED_ADMIN_EMAIL=ADMIN_EMAIL
SEED_DISPATCHER_EMAIL=DISPATCHER_EMAIL
SEED_DRIVER_1_EMAIL=DRIVER1_EMAIL
SEED_DRIVER_2_EMAIL=DRIVER2_EMAIL
# Driver login accounts: create users in Firebase Console → Authentication first,
# then run `npm run seed:firebase` to set custom claims and link authUid on driver docs.

# External Order Provider (mock by default — live reads/sync require explicit flags)
EXTERNAL_ORDER_PROVIDER_MODE=mock
EXTERNAL_ORDER_API_BASE_URL=
EXTERNAL_ORDER_API_PATH_PREFIX=/swagger
EXTERNAL_ORDER_API_KEY=
EXTERNAL_ORDER_API_PASS=
EXTERNAL_ORDER_LOCATION_ID=
EXTERNAL_ORDER_OTP=
EXTERNAL_ORDER_WEBHOOK_SECRET=
EXTERNAL_ORDER_LIVE_READS_ENABLED=false
EXTERNAL_ORDER_LIVE_SYNC_ENABLED=false
# Max 20 — delivery orders may appear deep in Barnet pagination (e.g. page 10+)
EXTERNAL_ORDER_SYNC_PAGES=10
EXTERNAL_ORDER_SYNC_ITEMS_PER_PAGE=20
# Parallel Barnet page fetches during preview/sync (default 4; scan uses sequential pages)
# EXTERNAL_ORDER_SYNC_PAGE_CONCURRENCY=4
# Live scan script overrides (npm run order-provider:live-scan)
# ORDER_PROVIDER_SCAN_PAGES=20
# ORDER_PROVIDER_ITEMS_PER_PAGE=20
# ORDER_PROVIDER_DEBUG_CLASSIFICATION=true
# BARNET_DEBUG_ORDER_ID=
# Block customer SMS from synced external orders until phone source is confirmed
EXTERNAL_ORDER_CUSTOMER_MESSAGING_ENABLED=false

# Tracking links (public consumer page)
# Days until a secure tracking link expires (default 30)
# TRACKING_LINK_TTL_DAYS=30
# Hours after delivery when consumers can no longer add instructions (default 72)
# TRACKING_NOTE_TERMINAL_HOURS=72
# Max note submissions per token hash + IP per hour (default 5)
# TRACKING_NOTE_RATE_LIMIT_PER_HOUR=5
# Max tracking page reads per token hash + IP per minute (default 30)
# TRACKING_READ_RATE_LIMIT_PER_MINUTE=30
# Max invalid-token attempts per IP per minute (default 20)
# TRACKING_INVALID_RATE_LIMIT_PER_MINUTE=20
# Proof signed URL lifetime in milliseconds (default 15 minutes)
# PROOF_SIGNED_URL_TTL_MS=900000
# Max decoded proof file size in bytes (default 2621440 / ~2.5 MB)
# PROOF_MAX_UPLOAD_BYTES=2621440
# Max encoded data URL length in characters (default 3500000 / ~3.5 MB)
# PROOF_MAX_DATA_URL_CHARS=3500000
# Max image dimension — client should resize; server validates byte size (default 2048)
# PROOF_MAX_IMAGE_DIMENSION=2048
# Max proof uploads per driver per hour (default 60)
# PROOF_RATE_LIMIT_PER_DRIVER_PER_HOUR=60
# Max proof uploads per order per minute (default 10)
# PROOF_RATE_LIMIT_PER_ORDER_PER_MINUTE=10
# Min milliseconds between same proof-type uploads per order (default 5000)
# PROOF_DUPLICATE_WINDOW_MS=5000

# Twilio SMS (customer tracking-link notifications)
# All values are server-only — never use NEXT_PUBLIC_ for Twilio credentials.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# Test-only provider override (vitest): SMS_PROVIDER=test

# Vercel cron auth (Bearer token for /api/cron/* routes)
CRON_SECRET=

# Barnet sync schedule: vercel.json uses */15 * * * * (every 15 minutes).
# Sub-hourly crons require Vercel Pro (or higher). Hobby is limited to daily crons.
# Quiet hours 12:00 AM–8:30 AM America/Edmonton are enforced on the server
# (skipped cron ticks return ok + outside_operating_hours and do not call Barnet).

# Barnet sync tuning (optional)
# EXTERNAL_ORDER_SYNC_CONSECUTIVE_KNOWN_THRESHOLD=20
# EXTERNAL_ORDER_UPSTREAM_TIMEOUT_MS=30000
# EXTERNAL_ORDER_ENRICHMENT_CONCURRENCY=4
# EXTERNAL_ORDER_SYNC_LOCK_TTL_MS=900000