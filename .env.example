# Firebase Client
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID

# Firebase Admin
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_CLIENT_EMAIL=YOUR_FIREBASE_CLIENT_EMAIL
FIREBASE_PRIVATE_KEY="YOUR_FIREBASE_PRIVATE_KEY"

# App
NEXT_PUBLIC_APP_URL=YOUR_APP_URL
NEXT_PUBLIC_USE_API=true
# Dev only: each browser tab keeps its own login (admin + driver in separate tabs).
# Enabled automatically in development. Set to "false" to disable.
# NEXT_PUBLIC_TAB_SCOPED_AUTH=true

# Seed users
SEED_ADMIN_EMAIL=ADMIN_EMAIL
SEED_DISPATCHER_EMAIL=DISPATCHER_EMAIL
SEED_DRIVER_1_EMAIL=DRIVER1_EMAIL
SEED_DRIVER_2_EMAIL=DRIVER2_EMAIL

# External Order Provider (mock by default — live reads/sync require explicit flags)
EXTERNAL_ORDER_PROVIDER_MODE=mock
EXTERNAL_ORDER_API_BASE_URL=
EXTERNAL_ORDER_API_PATH_PREFIX=/swagger
EXTERNAL_ORDER_API_KEY=
EXTERNAL_ORDER_API_PASS=
EXTERNAL_ORDER_LOCATION_ID=
EXTERNAL_ORDER_OTP=
EXTERNAL_ORDER_WEBHOOK_SECRET=
EXTERNAL_ORDER_LIVE_READS_ENABLED=false
EXTERNAL_ORDER_LIVE_SYNC_ENABLED=false
# Max 20 — delivery orders may appear deep in Barnet pagination (e.g. page 10+)
EXTERNAL_ORDER_SYNC_PAGES=10
EXTERNAL_ORDER_SYNC_ITEMS_PER_PAGE=20
# Parallel Barnet page fetches during preview/sync (default 4; scan uses sequential pages)
# EXTERNAL_ORDER_SYNC_PAGE_CONCURRENCY=4
# Live scan script overrides (npm run order-provider:live-scan)
# ORDER_PROVIDER_SCAN_PAGES=20
# ORDER_PROVIDER_ITEMS_PER_PAGE=20
# ORDER_PROVIDER_DEBUG_CLASSIFICATION=true
# BARNET_DEBUG_ORDER_ID=
# Block customer SMS from synced external orders until phone source is confirmed
EXTERNAL_ORDER_CUSTOMER_MESSAGING_ENABLED=false

# Vercel cron auth (Bearer token for /api/cron/* routes)
CRON_SECRET=

# Barnet sync tuning (optional)
# EXTERNAL_ORDER_SYNC_CONSECUTIVE_KNOWN_THRESHOLD=20
# EXTERNAL_ORDER_UPSTREAM_TIMEOUT_MS=30000
# EXTERNAL_ORDER_ENRICHMENT_CONCURRENCY=4
# EXTERNAL_ORDER_SYNC_LOCK_TTL_MS=900000