{
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "../node_modules/**": true,
    "../**/node_modules/**": true,
    "../**/.next/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "../node_modules": true
  },
  "typescript.tsdk": "node_modules/typescript/lib"
}
