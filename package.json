{
  "name": "quick-run-express",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/predev-check.mjs",
    "kill:dev": "lsof -ti:3000,3001 | xargs kill -9 2>/dev/null || true",
    "dev": "next dev --webpack --port 3000",
    "dev:turbo": "next dev --port 3000",
    "clean": "rm -rf .next tsconfig.tsbuildinfo",
    "dev:clean": "npm run kill:dev && npm run clean && npm run dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "optimize:images": "node scripts/optimize-public-media.mjs",
    "process:knockout-backgrounds": "node scripts/knockout-white-background.mjs",
    "seed:firebase": "node scripts/seed-firebase.mjs",
    "order-provider:health": "node scripts/check-order-provider-health.mjs",
    "order-provider:live-config": "node scripts/check-live-order-provider-config.mjs",
    "order-provider:live-scan": "node scripts/check-live-barnet-delivery-scan.mjs",
    "firebase:emulators": "bash scripts/firebase-cli.sh emulators:start --only firestore,storage",
    "firebase:rules-test": "bash scripts/firebase-cli.sh emulators:exec --only firestore,storage \"vitest run --config vitest.rules.config.ts\"",
    "firebase:deploy:rules": "bash scripts/firebase-cli.sh deploy --only firestore:rules,firestore:indexes,storage"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "firebase": "^12.15.0",
    "firebase-admin": "13.10.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "^19",
    "react-dom": "^19",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "happy-dom": "^20.10.6",
    "firebase-tools": "^15.0.0",
    "postcss": "^8.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3",
    "vitest": "^4.1.10"
  }
}
